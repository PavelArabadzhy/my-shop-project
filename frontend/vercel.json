{
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/api/assets/:path*"
    },
    {
      "source": "/product",
      "destination": "/product.html"
    },
    {
      "source": "/cart",
      "destination": "/cart.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}