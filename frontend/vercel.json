{
  "rewrites": [
    {
      "source": "/metrics/:path*",
      "destination": "/api/metrics/:path*"
    },
    {
      "source": "/product",
      "destination": "/product.html"
    },
    {
      "source": "/cart",
      "destination": "/cart.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}